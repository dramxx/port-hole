{
  "name": "port-hole-server",
  "version": "1.0.0",
  "description": "Bridge server for remote OpenCode control via Tailscale",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.4.1",
    "eventsource": "^2.0.2",
    "fastify": "^5.8.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.16",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "playwright": "^1.41.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
